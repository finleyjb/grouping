{
  "compilerOptions": {
    "target": "es2018",
    "module": "node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "strict": true,
    "noEmit": false,
    "declaration": true,
    "outDir": "./dist",
    "jsx": "react",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false
  },
  "exclude": [
    "**/errors.ts",
    "**/*.test.ts",
    "dist",
    "vitest.config.ts",
    "tsdown.config.ts"
  ]
}
